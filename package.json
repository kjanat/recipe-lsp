{
	"name": "recipe-lsp",
	"version": "0.2.0",
	"description": "Language Server Protocol server for the recipe (.recipe) pharmacological notation language.",
	"keywords": [
		"lsp",
		"language-server",
		"recipe",
		"pharmacology",
		"tree-sitter"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/recipe-lsp.git"
	},
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"type": "module",
	"imports": {
		"#src/*": "./src/*",
		"#anal/*": "./src/analysis/*",
		"#runtime/*": "./src/runtime/*",
		"#server/*": "./src/server/*",
		"#vocab/*": "./src/vocabulary/*",
		"#testsupport/*": "./tests/support/*"
	},
	"exports": {
		".": {
			"types": "./dist/server.d.mts",
			"default": "./dist/server.mjs"
		},
		"./browser": {
			"types": "./dist/browser.d.ts",
			"default": "./dist/browser.js"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/server.mjs",
	"types": "./dist/server.d.mts",
	"bin": {
		"recipe-lsp": "dist/server.mjs"
	},
	"files": [
		"dist/**",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"bd": "bun run build",
		"build": "tsdown",
		"check": "biome check",
		"dev": "bun run server.ts --stdio",
		"fmt": "dprint fmt",
		"lint": "biome lint",
		"prepack": "bun run build",
		"prestart": "bun run build",
		"start": "node ./dist/server.mjs --stdio",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"tree-sitter-recipe": "^0.3.0",
		"vscode-languageserver": "^9.0.1",
		"vscode-languageserver-textdocument": "^1.0.12",
		"web-tree-sitter": "^0.26.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/bun": "^1.3.13",
		"dprint": "^0.54.0",
		"rolldown-plugin-wasm": "^0.2.1",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3"
	},
	"packageManager": "bun@1.3.14",
	"patchedDependencies": {
		"web-tree-sitter@0.26.8": "patches/web-tree-sitter@0.26.8.patch"
	},
	"trustedDependencies": [
		"tree-sitter-recipe"
	]
}
