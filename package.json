{
	"name": "recipe-lsp",
	"version": "0.2.0",
	"description": "Language Server Protocol server for the recipe (.recipe) pharmacological notation language.",
	"keywords": [
		"lsp",
		"language-server",
		"recipe",
		"pharmacology",
		"tree-sitter"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/recipe-lsp.git"
	},
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"type": "module",
	"imports": {
		"#src/*": "./src/*",
		"#anal/*": "./src/analysis/*",
		"#runtime/*": "./src/runtime/*",
		"#server/*": "./src/server/*",
		"#vocab/*": "./src/vocabulary/*",
		"#testsupport/*": "./tests/support/*",
		"#plugins/*": "./plugins/*.ts",
		"#pkg": "./package.json"
	},
	"exports": {
		".": "./dist/index.js",
		"./browser": "./dist/browser.js",
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"bin": {
		"recipe-lsp": "dist/server.js"
	},
	"files": [
		"/package.json",
		"/dist",
		"/README.md",
		"/LICENSE"
	],
	"scripts": {
		"bd": "run build",
		"build": "tsdown",
		"check": "biome check",
		"fmt": "dprint fmt",
		"lint": "biome lint",
		"lsp": "bun server.ts --stdio",
		"prepack": "run build",
		"prestart": "run build",
		"start": "node dist/server.js --stdio",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"tree-sitter-recipe": "^0.3.0",
		"vscode-languageserver": "^10.0.1",
		"vscode-languageserver-textdocument": "^1.0.12",
		"web-tree-sitter": "^0.26.10"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.4",
		"@biomejs/biome": "^2.5.1",
		"@types/bun": "^1.3.14",
		"dprint": "^0.55.1",
		"publint": "^0.3.21",
		"rolldown-plugin-wasm": "^0.3.2",
		"runner-run": "^0.14.3",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3",
		"unplugin-unused": "^0.5.7"
	},
	"packageManager": "bun@1.3.14",
	"trustedDependencies": [
		"tree-sitter-recipe"
	]
}
